# .gitignore for the Steal the Loot Knapsack Game

# General
# ----------------
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS-generated files
.DS_Store
Thumbs.db
._*

# IDE and Editor configuration
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Node.js (for both /backend and /frontend)
# ------------------------------------------
# Dependencies - This is the most important rule!
node_modules/

# Environment variables - Do not commit secrets!
.env
.env.*
!.env.example

# Build output from frontend (Vite)
/frontend/dist
/frontend/.vite

# Test reports, coverage, etc.
coverage/
.nyc_output/

# C Algorithm
# -----------
# Compiled executable from knapsack.c
/algorithm/knapsack_solver
/algorithm/knapsack_solver.exe

# Object files and other build artifacts
/algorithm/*.o
/algorithm/*.obj
/algorithm/*.out